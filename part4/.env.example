# Copy this file to .env in the same folder and fill in your real key:
#   cp .env.example .env
#
# .env is loaded automatically by part4_llm_explanation.py via python-dotenv.
# Never commit your real .env file -- it's already excluded in .gitignore.

# Required: your API key
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_REAL_KEY

# Optional: only needed if you're using a non-OpenAI, OpenAI-compatible
# provider (Azure OpenAI, Groq, Together, a local vLLM/Ollama server, etc.)
# Defaults to https://api.openai.com/v1 if not set.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override the model used for explanations. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini
